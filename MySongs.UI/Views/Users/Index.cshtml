@model IEnumerable<MySongs.Common.DTOs.UserDto>
@{
    ViewData["Title"] = "Users";
}
<h1>Users</h1>
<p><a asp-action="Create">Create New</a></p>
<table class="table">
    <thead>
        <tr>
            <th>UserId</th>
            <th>Username</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.UserId</td>
                <td>@item.Username</td>
                <td>@item.Email</td>
            </tr>
        }
    </tbody>
</table>